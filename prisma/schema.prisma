// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(uuid())
  name String     
  email String @unique
  password String 
  role userRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  
  reservations Reservation[] @relation("reserver")
  organizedEvents Event[] @relation("organizer")

}

model Event{
  id String @id @default(uuid())
  userId String                                                             
  name String
  totalSeats Int
  availableSeats Int                   
  createdAt DateTime @default(now())
  eventDate DateTime
  category eventCategory
  isDelete Boolean @default(false)
  reservations Reservation[] @relation("event")
  organizer User @relation("organizer", fields: [userId], references: [id], onDelete: Cascade)
  @@index([eventDate])
  @@index([userId])
}

model Reservation{
  id String @id @default(uuid())
  eventId String 
  userId String
  status reservationStatus @default(RESERVED)
  expiresAt DateTime     
  version Int @default(1)
  createdAt DateTime @default(now())

  event Event @relation("event", fields: [eventId], references: [id], onDelete: Cascade)
  reserver User @relation("reserver", fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[] @relation("reservation")     //multiple payments allowed incase of failure, but check if success before payment
  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@index([expiresAt])
}

model Payment{
  id String @id @default(uuid())
  reservationId String         
  idempotencyKey String @unique
  status paymentStatus @default(PENDING)
  createdAt DateTime @default(now())
  reservation Reservation @relation("reservation", fields: [reservationId], references: [id], onDelete: Cascade)
  @@index([createdAt])
  @@index([reservationId])
}

enum reservationStatus{
  RESERVED
  PAID
  EXPIRED
}

enum paymentStatus{
  COMPLETED
  PENDING 
  FAILED    
}  

enum userRole{
  ORGANIZER 
  CUSTOMER
  ADMIN
}

enum eventCategory{
  CONFERENCE
  WORKSHOP
  MEETUP
  CONCERT
  EXHBITION
  RELIGOUS
  ONLINE
  COMMUNITY
  CEREMONY  
}